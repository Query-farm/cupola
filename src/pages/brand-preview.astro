      </div>

      <div class="bp-scale-label"><span class="title font-heading">Soil</span><span class="desc">page bg · borders · body text · footer</span></div>
      <div class="bp-swatch-grid">
        <div class="bp-swatch" style="background:#f7f6f4;color:#3d342a"><span class="name">50</span><span class="hex">#f7f6f4</span></div>
        <div class="bp-swatch" style="background:#e8e4df;color:#3d342a"><span class="name">100</span><span class="hex">#e8e4df</span></div>
        <div class="bp-swatch" style="background:#d3cab9;color:#3d342a"><span class="name">200</span><span class="hex">#d3cab9</span></div>
        <div class="bp-swatch" style="background:#baab8e;color:#3d342a"><span class="name">300</span><span class="hex">#baab8e</span></div>
        <div class="bp-swatch" style="background:#a18c68;color:#fff"><span class="name">400</span><span class="hex">#a18c68</span></div>
        <div class="bp-swatch" style="background:#8a754f;color:#fff"><span class="name">500</span><span class="hex">#8a754f</span></div>
