      <div class="bp-swatch-grid" style="grid-template-columns: repeat(4, 1fr); max-width: 480px;">
        <div class="bp-swatch" style="background:#fffbeb;color:#78350f"><span class="name">50</span><span class="hex">#fffbeb</span></div>
        <div class="bp-swatch" style="background:#fef3c7;color:#78350f"><span class="name">100</span><span class="hex">#fef3c7</span></div>
