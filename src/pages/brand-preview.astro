        <div class="bp-swatch" style="background:#86efac;color:#14532d"><span class="name">300</span><span class="hex">#86efac</span></div>
        <div class="bp-swatch" style="background:#4ade80;color:#14532d"><span class="name">400</span><span class="hex">#4ade80</span></div>
        <div class="bp-swatch" style="background:#22c55e;color:#fff"><span class="name">500</span><span class="hex">#22c55e</span></div>
        <div class="bp-swatch" style="background:#16a34a;color:#fff"><span class="name">600</span><span class="hex">#16a34a</span></div>
        <div class="bp-swatch" style="background:#15803d;color:#fff"><span class="name">700</span><span class="hex">#15803d</span></div>
