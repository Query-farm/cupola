        <div class="bp-swatch" style="background:#5a4a36;color:#fff"><span class="name">700</span><span class="hex">#5a4a36</span></div>
        <div class="bp-swatch" style="background:#4a3e2f;color:#fff"><span class="name">800</span><span class="hex">#4a3e2f</span></div>
        <div class="bp-swatch" style="background:#3d342a;color:#fff"><span class="name">900</span><span class="hex">#3d342a</span></div>
      </div>

      <div class="bp-scale-label"><span class="title font-heading">Harvest</span><span class="desc">primary CTA · sidebar selection · focus rings</span></div>
      <div class="bp-swatch-grid">
        <div class="bp-swatch" style="background:#f0fdf4;color:#14532d"><span class="name">50</span><span class="hex">#f0fdf4</span></div>
        <div class="bp-swatch" style="background:#dcfce7;color:#14532d"><span class="name">100</span><span class="hex">#dcfce7</span></div>
